# Project 330 Environment Variables

# 1. Strava API Configuration
# Strava Developer Settings (https://www.strava.com/settings/api)에서 확인 가능한 정보들입니다.
STRAVA_CLIENT_ID=YOUR_STRAVA_CLIENT_ID
STRAVA_CLIENT_SECRET=YOUR_STRAVA_CLIENT_SECRET

# 최초 토큰 발급 스크립트를 통해 얻게 되는 Refresh Token입니다.
STRAVA_REFRESH_TOKEN=YOUR_STRAVA_REFRESH_TOKEN

# 2. AI Coach Configuration (Gemini API)
# 구글 AI 스튜디오(https://aistudio.google.com/)에서 무료로 API Key를 발급받을 수 있습니다.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# 3. Webhook Settings (개발 단계에서는 기본값 사용 가능)
WEBHOOK_VERIFY_TOKEN=PROJECT330_TOKEN
